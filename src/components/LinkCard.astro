---
interface Props {
  href?: string;
  title: string;
  subtitle: string;
  icon?: string;
  trailingIcon?: string;
  style?: string;
  isContact?: boolean;
}

const { href, title, subtitle, trailingIcon, style, isContact } = Astro.props;
---

{href && !isContact ? (
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="link-card group flex items-center gap-4 w-full"
    style={style}
  >
    <div class="flex-1 min-w-0">
      <h3 class="font-display font-semibold text-foreground group-hover:text-primary transition-colors">
        {title}
      </h3>
      <p class="text-sm text-muted-foreground truncate">{subtitle}</p>
    </div>
    {trailingIcon && (
      <span class="text-2xl text-muted-foreground opacity-70 group-hover:opacity-100 transition-opacity">{trailingIcon}</span>
    )}
  </a>
) : (
  <button
    type="button"
    class="link-card group flex items-center gap-4 w-full text-left cursor-pointer"
    id={isContact ? 'openModal' : undefined}
    onclick={isContact ? "window.openModal()" : undefined}
    style={style}
  >
    <div class="flex-1 min-w-0">
      <h3 class="font-display font-semibold text-foreground group-hover:text-primary transition-colors">
        {title}
      </h3>
      <p class="text-sm text-muted-foreground truncate">{subtitle}</p>
    </div>
    {trailingIcon && (
      <span class="text-2xl text-muted-foreground opacity-70 group-hover:opacity-100 transition-opacity">{trailingIcon}</span>
    )}
  </button>
)}